# Copy to `.env.local` and fill in values. Never commit `.env.local` (see .gitignore).

# --- App URLs ---
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_BRAND_NAME=

# --- Supabase (pick one style) ---
# Option A: single pair for all environments
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Option B: staging (Preview / local) vs production
SUPABASE_URL_STAGING=
SUPABASE_SERVICE_ROLE_KEY_STAGING=
SUPABASE_URL_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=
# Optional: cap outbound Supabase HTTP wait (ms) to avoid serverless 504s
# SUPABASE_FETCH_TIMEOUT_MS=12000

# --- Stripe ---
STRIPE_LIVE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_99=
STRIPE_PRICE_SETUP_399=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# RESEND_FETCH_TIMEOUT_MS=12000

# --- Maps / geocoding / data APIs ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
NREL_API_KEY=
EIA_API_KEY=
OPENEI_API_KEY=

# --- Auth / admin ---
JWT_SECRET=
ADMIN_TOKEN=

# --- Vercel (custom domains) ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# --- Redis / KV (rate limits, etc.) ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
REDIS_URL=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# --- Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=

# --- E2E / Playwright (optional) ---
# NEXT_PUBLIC_E2E=1
# E2E_DEMO_COMPANY=Metaca
# E2E_DASHBOARD_HANDLE=metaca
# E2E_PAID_COMPANY=paid

# --- Financial defaults (optional; see src/config/env.ts) ---
# DEFAULT_RATE_ESCALATION=0.025
# DEFAULT_OANDM_ESCALATION=0.03
# DISCOUNT_RATE=0.08
# OANDM_PER_KW_YEAR=15
# DEFAULT_DEGRADATION_PCT=0.5
# DEFAULT_LOSSES_PCT=14
# DEFAULT_COST_PER_WATT=3.5

# --- Legacy / migration (optional) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- Misc ---
EL_CNAME_TARGET=
ALLOW_EMBED=
